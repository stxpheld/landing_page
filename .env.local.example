# ── Configuration de la landing page ──────────────────────────────
# Copiez ce fichier en `.env.local` et remplissez les valeurs.

# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://agence-ia.fr

# Email de contact affiché et destinataire par défaut du formulaire
NEXT_PUBLIC_CONTACT_EMAIL=contact@agence-ia.fr

# Réservation d'appel — lien Cal.com au format "utilisateur/type-evenement"
# ex. stephane/appel-decouverte
NEXT_PUBLIC_CALCOM_LINK=

# Réseaux sociaux (laisser vide pour masquer)
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# Mesure d'audience Plausible (domaine sans https). Laisser vide pour désactiver.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Côté serveur (formulaire de contact) ──────────────────────────
# Clé API Resend — sans elle, le formulaire fonctionne mais n'envoie pas d'email.
RESEND_API_KEY=
# Destinataire des demandes (sinon NEXT_PUBLIC_CONTACT_EMAIL)
CONTACT_TO_EMAIL=
# Expéditeur vérifié sur Resend (domaine validé requis en production)
CONTACT_FROM_EMAIL=Agence IA <onboarding@resend.dev>
